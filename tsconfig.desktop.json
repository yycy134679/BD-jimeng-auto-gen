{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "electron"],
    "outDir": "dist-desktop",
    "rootDir": "."
  },
  "include": ["desktop/main/**/*.ts", "desktop/preload/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-desktop", "tests"]
}
